# Copy to .env and fill in. setup.bat will generate one for you on Windows.
NODE_ENV=production
PORT=3000

# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Optional
# DB_PATH=./driven.db
# CORS_ORIGIN=https://your.domain
# COOKIE_SECURE=1
# TRUST_PROXY=1
